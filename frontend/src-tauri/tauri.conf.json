{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PhotoVault",
  "version": "0.1.0",
  "identifier": "com.photovault.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PhotoVault",
        "width": 1360,
        "height": 860,
        "minWidth": 1180,
        "minHeight": 740,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.photovault/thumbs/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/photovault-bridge.exe",
      "resources/ffmpeg.exe",
      "resources/ffprobe.exe",
      "resources/exiftool"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
